---
interface BreadcrumbItem {
  name: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-muted-foreground mb-4">
  <ol class="flex flex-wrap items-center gap-1.5">
    <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
    {items.map((item) => (
      <li class="flex items-center gap-1.5">
        <span aria-hidden="true">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-foreground transition-colors">{item.name}</a>
        ) : (
          <span class="text-foreground font-medium">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
