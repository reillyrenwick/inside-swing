---

<section class="mt-12 hero-gradient rounded-xl p-8 text-center">
  <h2 class="font-display text-2xl font-semibold text-primary-foreground mb-2">Stay in the Loop</h2>
  <p class="text-primary-foreground/80 mb-5 max-w-md mx-auto">Get weekly rankings updates, destination guides, and insider tips delivered to your inbox.</p>
  <form class="flex max-w-md mx-auto gap-2" action="#" method="post">
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-4 py-2.5 rounded-lg bg-primary-foreground/10 border border-primary-foreground/20 text-primary-foreground placeholder:text-primary-foreground/50 focus:outline-none focus:ring-2 focus:ring-gold"
    />
    <button type="submit" class="px-5 py-2.5 rounded-lg bg-gold text-foreground font-semibold hover:bg-gold-light transition-colors">
      Subscribe
    </button>
  </form>
</section>
