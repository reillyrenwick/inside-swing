---
interface Props {
  title?: string;
  heading?: string;
  links: ({ name: string; slug: string; prefix?: string } | { name: string; href: string })[];
}

const { title, heading, links } = Astro.props;
const displayTitle = title || heading || 'Related';
---

{links.length > 0 && (
  <section class="mt-10">
    <h2 class="font-display text-xl font-semibold mb-4">{displayTitle}</h2>
    <div class="flex flex-wrap gap-3">
      {links.map((link) => {
        const href = 'href' in link ? link.href : `${link.prefix || '/best-golf-courses-in/'}${link.slug}`;
        return (
          <a href={href}
            class="px-4 py-2 rounded-lg bg-muted hover:bg-primary hover:text-primary-foreground transition-colors text-sm font-medium">
            {link.name}
          </a>
        );
      })}
    </div>
  </section>
)}
