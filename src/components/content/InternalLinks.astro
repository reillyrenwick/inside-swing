---
interface Props {
  title: string;
  links: { name: string; slug: string; prefix?: string }[];
}

const { title, links } = Astro.props;
---

{links.length > 0 && (
  <section class="mt-10">
    <h2 class="font-display text-xl font-semibold mb-4">{title}</h2>
    <div class="flex flex-wrap gap-3">
      {links.map((link) => (
        <a href={`${link.prefix || '/best-golf-courses-in/'}${link.slug}`}
          class="px-4 py-2 rounded-lg bg-muted hover:bg-primary hover:text-primary-foreground transition-colors text-sm font-medium">
          {link.name}
        </a>
      ))}
    </div>
  </section>
)}
