---
import EditorialLayout from '../../layouts/EditorialLayout.astro';
import NewsletterCTA from '../../components/content/NewsletterCTA.astro';
import { architects } from '../../lib/architects';
import { buildBreadcrumbSchema, buildItemListSchema } from '../../lib/schema';
import { SITE_NAME } from '../../lib/config';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Golf Course Architects' },
];

const jsonLd = [
  buildBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Golf Course Architects', url: '/architects' },
  ]),
  buildItemListSchema(
    'Golf Course Architects',
    architects.map((a, i) => ({
      name: a.name,
      position: i + 1,
      url: `/architects/${a.slug}`,
    }))
  ),
];
---

<EditorialLayout
  title={`Golf Course Architects | ${SITE_NAME}`}
  description="Explore profiles of America's greatest golf course architects. From Tom Fazio to Coore & Crenshaw, discover the designers behind the world's finest courses."
  canonical="/architects"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <header class="mb-10">
    <h1 class="font-display text-3xl md:text-4xl font-bold mb-4">Golf Course Architects</h1>
    <p class="text-lg text-muted-foreground max-w-3xl">
      The designers and visionaries behind America's greatest golf courses. Explore architect profiles, design philosophies, and notable works.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {architects.map((a) => (
      <a href={`/architects/${a.slug}`} class="surface-elevated rounded-lg p-6 hover:ring-2 hover:ring-primary/20 transition-all group">
        <h2 class="font-display text-lg font-semibold group-hover:text-primary transition-colors">{a.name}</h2>
        <p class="text-sm text-muted-foreground mt-2 line-clamp-3">{a.bio.slice(0, 150)}...</p>
        {a.notableCourses.length > 0 && (
          <p class="text-xs text-muted-foreground mt-3">
            {a.notableCourses.length} notable {a.notableCourses.length === 1 ? 'course' : 'courses'}
          </p>
        )}
        <p class="text-sm font-medium text-primary mt-3">View profile &rarr;</p>
      </a>
    ))}
  </div>

  <NewsletterCTA />
</EditorialLayout>
