---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterCTA from '../components/content/NewsletterCTA.astro';
import { getAllCities, getAllStates, getAllRankings, getAllCourses } from '../lib/data';
import { travelDestinations } from '../lib/travel';
import { architects } from '../lib/architects';
import { buildOrganizationSchema, buildWebsiteSchema } from '../lib/schema';
import { SITE_NAME, CURRENT_YEAR } from '../lib/config';

const cities = getAllCities();
const states = getAllStates();
const rankings = getAllRankings();
const allCourses = getAllCourses();

const enrichedCourses = allCourses
  .filter(c => c.history && c.signatureHoles && c.signatureHoles.length > 0)
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 6);

const topCities = cities.slice(0, 12);
const topTravel = travelDestinations.slice(0, 6);
const topArchitects = architects.slice(0, 8);

const totalCourses = allCourses.length;
const totalStates = new Set(allCourses.map(c => c.state)).size;
const totalCities = cities.length;

const jsonLd = [buildOrganizationSchema(), buildWebsiteSchema()];

const typeColors: Record<string, string> = {
  public: 'bg-green-100 text-green-800',
  private: 'bg-purple-100 text-purple-800',
  resort: 'bg-blue-100 text-blue-800',
  'semi-private': 'bg-amber-100 text-amber-800',
};
---

<BaseLayout
  title={`${SITE_NAME} | Best Golf Courses, Rankings & Travel Guides ${CURRENT_YEAR}`}
  description={`Discover America's best golf courses with expert rankings, ${totalCities}+ city guides, destination reviews, and travel planning. Updated for ${CURRENT_YEAR}.`}
  canonical="/"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="hero-gradient py-20 md:py-28">
    <div class="editorial-container text-center">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-primary-foreground mb-4">
        <span class="gold-accent">The Inside</span> Swing
      </h1>
      <p class="text-lg md:text-xl text-primary-foreground/80 max-w-2xl mx-auto mb-8">
        Expert-curated golf course rankings, in-depth reviews, and destination guides for the discerning golfer.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/rankings" class="btn-gold">Browse Rankings</a>
        <a href="/golf-travel" class="btn-secondary" style="border-color: hsl(var(--gold)); color: hsl(var(--primary-foreground));">Plan a Golf Trip</a>
      </div>
      <div class="grid grid-cols-3 gap-6 max-w-lg mx-auto">
        <div class="text-center">
          <div class="stat-value">{totalCourses}+</div>
          <div class="stat-label">Courses</div>
        </div>
        <div class="text-center">
          <div class="stat-value">{totalCities}</div>
          <div class="stat-label">Cities</div>
        </div>
        <div class="text-center">
          <div class="stat-value">{totalStates}</div>
          <div class="stat-label">States & Provinces</div>
        </div>
      </div>
    </div>
  </section>

  <div class="editorial-container py-12 md:py-16">

    <!-- Featured Courses -->
    {enrichedCourses.length > 0 && (
      <section class="mb-16">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="font-display text-2xl md:text-3xl font-semibold">Featured Courses</h2>
            <p class="text-muted-foreground mt-1">In-depth profiles of America's finest</p>
          </div>
          <a href="/rankings/best-golf-courses-in-america" class="hidden sm:inline-flex text-sm font-medium text-primary hover:underline">
            View all rankings &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {enrichedCourses.map((course) => (
            <a href={`/golf-course/${course.slug}`} class="card-interactive p-6 group">
              <div class="flex items-start justify-between mb-3">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-semibold ${typeColors[course.type] || 'bg-gray-100 text-gray-800'}`}>
                  {course.type}
                </span>
                <span class="flex items-center gap-1 text-sm font-semibold">
                  <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {course.rating}
                </span>
              </div>
              <h3 class="font-display text-lg font-semibold group-hover:text-primary transition-colors mb-1">{course.name}</h3>
              <p class="text-sm text-muted-foreground mb-3">{course.city}, {course.state} &middot; {course.architect}</p>
              <p class="text-sm text-foreground/80 line-clamp-3">{course.description}</p>
              <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
                <span>{course.holes} holes &middot; Par {course.par} &middot; {course.yardage?.toLocaleString()} yds</span>
                {course.greensFee && <span class="font-semibold text-foreground">{course.greensFee}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Rankings -->
    <section class="mb-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-semibold">Rankings</h2>
          <p class="text-muted-foreground mt-1">Expert-curated lists updated for {CURRENT_YEAR}</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {rankings.map((r) => (
          <a href={`/rankings/${r.slug}`} class="card-interactive p-6 group">
            <h3 class="font-display text-lg font-semibold group-hover:text-primary transition-colors">{r.title}</h3>
            <p class="text-sm text-muted-foreground mt-2 line-clamp-2">{r.intro?.slice(0, 120) || 'Explore our expert rankings'}...</p>
            <span class="inline-block mt-4 text-sm font-medium text-primary">View rankings &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Popular Destinations -->
    <section class="mb-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-semibold">Popular Golf Destinations</h2>
          <p class="text-muted-foreground mt-1">City-by-city guides to the best courses</p>
        </div>
        <a href="/best-golf-courses-in" class="hidden sm:inline-flex text-sm font-medium text-primary hover:underline">
          All {totalCities} cities &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {topCities.map((c) => (
          <a href={`/best-golf-courses-in/${c.slug}`} class="card-interactive p-4 group">
            <h3 class="font-display text-base font-semibold group-hover:text-primary transition-colors">{c.city}</h3>
            <p class="text-xs text-muted-foreground mt-0.5">{c.state}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-6 sm:hidden">
        <a href="/best-golf-courses-in" class="text-sm font-medium text-primary hover:underline">View all {totalCities} cities &rarr;</a>
      </div>
    </section>

    <!-- Golf Travel Guides -->
    <section class="mb-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-semibold">Golf Travel Guides</h2>
          <p class="text-muted-foreground mt-1">Plan your next golf trip</p>
        </div>
        <a href="/golf-travel" class="hidden sm:inline-flex text-sm font-medium text-primary hover:underline">
          All guides &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topTravel.map((t) => (
          <a href={`/golf-travel/${t.slug}`} class="card-interactive p-6 group">
            <h3 class="font-display text-lg font-semibold group-hover:text-primary transition-colors">{t.destination}</h3>
            <p class="text-sm text-muted-foreground mt-2 line-clamp-2">{t.heroIntro.slice(0, 140)}...</p>
            <span class="inline-block mt-3 text-sm font-medium text-primary">Read guide &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- State Guides -->
    <section class="mb-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-semibold">Golf by State</h2>
          <p class="text-muted-foreground mt-1">Explore courses across {totalStates} states and provinces</p>
        </div>
        <a href="/golf-in" class="hidden sm:inline-flex text-sm font-medium text-primary hover:underline">
          All states &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
        {states.slice(0, 18).map((s) => (
          <a href={`/golf-in/${s.slug}`} class="px-4 py-3 rounded-lg bg-muted hover:bg-primary hover:text-primary-foreground transition-colors text-sm font-medium text-center">
            {s.state}
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href="/golf-in" class="text-sm font-medium text-primary hover:underline">View all {totalStates} states &rarr;</a>
      </div>
    </section>

    <!-- Featured Architects -->
    <section class="mb-16">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="font-display text-2xl md:text-3xl font-semibold">Featured Architects</h2>
          <p class="text-muted-foreground mt-1">The designers behind the greatest courses</p>
        </div>
        <a href="/architects" class="hidden sm:inline-flex text-sm font-medium text-primary hover:underline">
          All architects &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {topArchitects.map((a) => (
          <a href={`/architects/${a.slug}`} class="card-interactive p-4 group text-center">
            <h3 class="font-display text-base font-semibold group-hover:text-primary transition-colors">{a.name}</h3>
            <p class="text-xs text-muted-foreground mt-1">{a.notableCourses?.length || 0} notable courses</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Browse All Cities (collapsed for SEO link equity) -->
    <section class="mb-12">
      <details class="border border-border rounded-lg">
        <summary class="px-6 py-4 cursor-pointer font-display text-lg font-semibold hover:bg-muted/50 transition-colors list-none [&::-webkit-details-marker]:hidden flex items-center justify-between">
          <span>Browse All {totalCities} City Guides</span>
          <svg class="w-5 h-5 text-muted-foreground transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-6 pb-6 grid grid-cols-2 md:grid-cols-4 gap-2">
          {cities.map((c) => (
            <a href={`/best-golf-courses-in/${c.slug}`} class="px-3 py-2 rounded text-sm hover:bg-muted transition-colors">
              {c.city}, {c.state}
            </a>
          ))}
        </div>
      </details>
    </section>

    <!-- Browse All States (collapsed for SEO) -->
    <section class="mb-16">
      <details class="border border-border rounded-lg">
        <summary class="px-6 py-4 cursor-pointer font-display text-lg font-semibold hover:bg-muted/50 transition-colors list-none [&::-webkit-details-marker]:hidden flex items-center justify-between">
          <span>Browse All {totalStates} State & Province Guides</span>
          <svg class="w-5 h-5 text-muted-foreground transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-6 pb-6 grid grid-cols-2 md:grid-cols-4 gap-2">
          {states.map((s) => (
            <a href={`/golf-in/${s.slug}`} class="px-3 py-2 rounded text-sm hover:bg-muted transition-colors">
              {s.state}
            </a>
          ))}
        </div>
      </details>
    </section>

    <NewsletterCTA />
  </div>
</BaseLayout>
