---
import EditorialLayout from '../../layouts/EditorialLayout.astro';
import NewsletterCTA from '../../components/content/NewsletterCTA.astro';
import { getAllCities, cityMeta } from '../../lib/data';
import { buildBreadcrumbSchema, buildItemListSchema } from '../../lib/schema';
import { SITE_NAME } from '../../lib/config';

const cities = getAllCities();

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Public Course City Guides' },
];

const jsonLd = [
  buildBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Public Course City Guides', url: '/best-public-golf-courses-in' },
  ]),
  buildItemListSchema(
    'Best Public Golf Courses by City',
    cities.map((c, i) => ({
      name: `Best Public Courses in ${c.city}, ${c.state}`,
      position: i + 1,
      url: `/best-public-golf-courses-in/${c.slug}`,
    }))
  ),
];
---

<EditorialLayout
  title={`Best Public Golf Courses by City | ${SITE_NAME}`}
  description="Find the best public golf courses in cities across America. Daily-fee and municipal course guides with green fees, ratings, and expert recommendations."
  canonical="/best-public-golf-courses-in"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <header class="mb-10">
    <h1 class="font-display text-3xl md:text-4xl font-bold mb-4">Best Public Golf Courses by City</h1>
    <p class="text-lg text-muted-foreground max-w-3xl">
      Discover the top public and daily-fee golf courses in cities across the country. Courses you can play, ranked and reviewed by our editorial team.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {cities.map((c) => {
      const data = cityMeta[c.slug];
      return (
        <a href={`/best-public-golf-courses-in/${c.slug}`} class="surface-elevated rounded-lg p-6 hover:ring-2 hover:ring-primary/20 transition-all group">
          <h2 class="font-display text-lg font-semibold group-hover:text-primary transition-colors">{c.city}, {c.state}</h2>
          {data?.heroIntro && (
            <p class="text-sm text-muted-foreground mt-2 line-clamp-3">{data.heroIntro.slice(0, 150)}...</p>
          )}
          <p class="text-sm font-medium text-primary mt-3">View public courses &rarr;</p>
        </a>
      );
    })}
  </div>

  <NewsletterCTA />
</EditorialLayout>
